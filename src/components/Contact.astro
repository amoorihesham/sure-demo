---
import { content } from '@/content/contact';
---

<div class="bg-background backdrop-blur-xl border border-brand/60 rounded-3xl p-4 md:p-6 shadow-xl relative flex-1/2">
  <form class="space-y-4" onsubmit="evencontent.preventDefault();">
    <div class="space-y-3">
      <label class="text-sm font-medium text-slate-700 dark:text-gray-300">
        {content.firstName}
      </label>
      <input
        type="text"
        class="w-full bg-white border border-brand/40 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all text-base"
        placeholder={content.firstNamePlaceholder}
      />
    </div>

    <div class="space-y-3">
      <label class="text-sm font-medium text-slate-700 dark:text-gray-300">
        {content.emailField}
      </label>
      <input
        type="email"
        class="w-full bg-white border border-brand/40 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all text-base"
        placeholder={content.emailPlaceholder}
      />
    </div>

    <div class="space-y-3">
      <label class="text-sm font-medium text-slate-700 dark:text-gray-300">
        {content.message}
      </label>
      <textarea
        rows="4"
        class="w-full bg-white border border-brand/40 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all resize-none text-base"
        placeholder={content.messagePlaceholder}></textarea>
    </div>

    <button
      type="submit"
      class="w-full bg-linear-to-tr from-primary to-brand/40 font-semibold rounded-xl px-6 py-3 md:py-4 transition-colors text-background cursor-pointer text-base hover:from-primary/90 hover:to-brand/30"
    >
      {content.submit}
    </button>
  </form>
</div>
