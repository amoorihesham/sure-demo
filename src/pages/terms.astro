---
import PageWrapper from '@/layouts/Layout.astro';
import Header from '@/sections/header.astro';
import Footer from '@/sections/footer.astro';
import { content } from '@/content/terms';
---

<PageWrapper title="Clario 360 - Privacy Policy">
  <Header />
  <section class="space-y-12 max-w-360 mx-auto px-3 md:px-6 py-8">
    <div>
      <h1 class="text-3xl font-bold mb-2">{content.pageTitle}</h1>
      <p class="max-w-2xl">{content.description}</p>
    </div>
    <div>
      {
        content.bullets.map(b => (
          <div class="space-y-3 mb-10">
            <h3 class="text-lg font-semibold">{b.title}</h3>
            <p class="max-w-3xl">{b.description}</p>
            {b.points && (
              <ul class="px-8 space-y-2 list-disc">
                {b.points.map(p => (
                  <li>{p}</li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
  </section>
  <Footer />
</PageWrapper>
