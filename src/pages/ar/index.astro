    icon: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>`,
  },
  {
    title: 'تصميم واجهات المستخدم',
    description: 'تصميم واجهات المستخدم لضمان تجربة مستخدم مميزة وأداء عالي',
    icon: `<svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.965 1.178c.09.544.5 1.002 1.002 1.002h2.5c.501 0 .913-.458 1.003-1.002zM14.502 14.28L4.053 5.46a2.25 2.25 0 01-.137-3.136c.216-.254.495-.444.808-.544a2.25 2.25 0 011.666.195l10.82 10.44m0 0l-1.396 1.488m1.396-1.488L20.44 20.44a2.25 2.25 0 01-3.181 3.182l-8.673-8.673m11.854-3.19l-3.182-3.181m3.182 3.181l1.488-1.396a2.25 2.25 0 000-3.182l-5.657-5.657a2.25 2.25 0 00-3.182 0l-1.396 1.487" /></svg>`,
