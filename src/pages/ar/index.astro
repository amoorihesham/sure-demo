import { ArrowLeft } from 'lucide-react';

const testimonials = [
  {
    name: 'Sarah Jenkins',
    role: 'CTO, FinTech Next',
    content:
      'Sure completely transformed our backend architecture. The new API infrastructure they designed handles 10x our previous traffic with zero latency spikes or downtime.',
    rating: 5,
    avatar: 'S',
  },
  {
    name: 'Omar Al-Fayed',
    role: 'Founder, RetailFlow',
    content:
      'The level of engineering quality and attention to detail during our mobile app rebuild was staggering. They don’t just write code; they build scalable digital businesses.',
