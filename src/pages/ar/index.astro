---

<PageWrapper content={{ title: 'شور للحلول الرقمية' }} lang="ar" dir="rtl">
  <header
    class="flex justify-between items-center py-2 sticky top-0 bg-background/5 backdrop-blur-lg z-50"
  >
    <div class="shrink-0">
      <a
        href="/"
        class="block hover:scale-105 transition-transform duration-300"
      >
        <img
          src="/logo.svg"
          alt="logo"
          class="w-24 drop-shadow-[0_0_15px_rgba(0,0,0,0.1)] dark:drop-shadow-[0_0_15px_rgba(255,255,255,0.05)]"
        />
      </a>
    </div>

    <div class="flex items-center justify-between w-[70%] xl:w-2/3">
      <div
        class="flex items-center gap-2 p-1.5 rounded-full bg-slate-200/50 dark:bg-white/5 border border-slate-300/50 dark:border-white/10 backdrop-blur-md shadow-sm dark:shadow-md transition-all hover:bg-slate-300/70 dark:hover:bg-white/10"
      >
        <ModeToggle client:only />
        <LocaleToggle client:only />
      </div>

      <nav
        class="bg-slate-800/90 dark:bg-[#0a0f1d]/80 border border-slate-700/50 dark:border-white/10 text-white dark:text-gray-300 flex items-center gap-8 rounded-full px-8 py-3 backdrop-blur-xl shadow-lg dark:shadow-[0_8px_32px_rgba(0,0,0,0.2)]"
      >
        <a
          class="text-sm font-medium hover:text-primary cursor-pointer transition-colors duration-300 relative group"
        >
          الرئيسية
          <span
            class="absolute -bottom-1.5 left-1/2 w-0 h-0.5 bg-primary -translate-x-1/2 transition-all duration-300 group-hover:w-full rounded-full"
          ></span>
        </a>
        <a
          class="text-sm font-medium hover:text-primary cursor-pointer transition-colors duration-300 relative group"
        >
          من نحن
          <span
            class="absolute -bottom-1.5 left-1/2 w-0 h-0.5 bg-primary -translate-x-1/2 transition-all duration-300 group-hover:w-full rounded-full"
          ></span>
        </a>
        <a
          class="text-sm font-medium hover:text-primary cursor-pointer transition-colors duration-300 relative group"
        >
          خدماتنا
          <span
            class="absolute -bottom-1.5 left-1/2 w-0 h-0.5 bg-primary -translate-x-1/2 transition-all duration-300 group-hover:w-full rounded-full"
          ></span>
        </a>
        <a
          class="text-sm font-medium hover:text-primary cursor-pointer transition-colors duration-300 relative group"
        >
          العملاء
          <span
            class="absolute -bottom-1.5 left-1/2 w-0 h-0.5 bg-primary -translate-x-1/2 transition-all duration-300 group-hover:w-full rounded-full"
          ></span>
        </a>
        <a
          class="text-sm font-medium hover:text-primary cursor-pointer transition-colors duration-300 relative group"
        >
          تواصل معنا
          <span
            class="absolute -bottom-1.5 left-1/2 w-0 h-0.5 bg-primary -translate-x-1/2 transition-all duration-300 group-hover:w-full rounded-full"
          ></span>
        </a>
      </nav>
    </div>
  </header>
  <section class="w-full relative pb-20 overflow-hidden">
    <div
      class="w-full max-w-[1440px] mx-auto min-h-[700px] md:min-h-[85vh] bg-[#050814]/80 backdrop-blur-3xl rounded-[2rem] relative overflow-hidden border border-white/5 shadow-2xl flex flex-col justify-center"
    >
      <div
        class="absolute -top-1/2 -right-1/4 w-[80%] h-[80%] bg-primary/20 blur-[140px] rounded-full pointer-events-none"
      >
      </div>
      <div
        class="absolute -bottom-1/2 -left-1/4 w-[80%] h-[80%] bg-primary/10 blur-[130px] rounded-full pointer-events-none"
      >
      </div>

      <div
        class="absolute inset-x-0 bottom-0 h-[60%] z-0 flex justify-center pointer-events-none opacity-60"
      >
        <div
          class="w-[1.5px] bg-linear-to-b from-transparent to-primary/20 h-full relative mx-[6%]"
        >
          <span
            class="absolute rounded-full block w-full h-32 bg-linear-to-b from-transparent to-primary bottom-32 opacity-80 blur-[2px] animate-pulse"
          ></span>
        </div>
        <div
          class="w-[1.5px] bg-linear-to-b from-transparent to-primary/20 h-[80%] relative mx-[4%]"
        >
          <span
            class="absolute rounded-full block w-full h-40 bg-linear-to-b from-transparent to-primary/80 bottom-10 opacity-70 blur-[2px]"
          ></span>
        </div>
        <div
          class="w-px bg-linear-to-b from-transparent to-primary/10 h-[90%] relative mx-[7%]"
        >
          <span
            class="absolute rounded-full block w-full h-24 bg-linear-to-b from-transparent to-primary bottom-1/4 opacity-90 blur-[2px]"
          ></span>
        </div>
      </div>

      <div
        class="absolute inset-0 z-0 pointer-events-none opacity-10 animate-ping mix-blend-screen"
        style="background-image: 
                radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.8) 100%, transparent),
                radial-gradient(2px 2px at 40% 50%, rgba(255,255,255,0.3) 100%, transparent),
                radial-gradient(1.5px 1.5px at 80% 30%, rgba(255,255,255,0.6) 100%, transparent),
                radial-gradient(2.5px 2.5px at 90% 80%, rgba(255,255,255,0.4) 100%, transparent),
                radial-gradient(1px 1px at 30% 70%, rgba(255,255,255,0.9) 100%, transparent),
                radial-gradient(2px 2px at 60% 10%, rgba(255,255,255,0.5) 100%, transparent),
                radial-gradient(1px 1px at 70% 90%, rgba(255,255,255,0.7) 100%, transparent),
                radial-gradient(1.5px 1.5px at 20% 80%, rgba(255,255,255,0.6) 100%, transparent); 
             background-size: 140px 140px; background-repeat: repeat;"
      >
      </div>
      <div
        class="absolute inset-0 z-0 pointer-events-none opacity-5 mix-blend-screen"
        style="background-image: 
                radial-gradient(1.5px 1.5px at 15% 15%, rgba(255,255,255,0.5) 100%, transparent),
                radial-gradient(1px 1px at 85% 85%, rgba(255,255,255,0.7) 100%, transparent),
                radial-gradient(2px 2px at 50% 25%, rgba(255,255,255,0.4) 100%, transparent); 
             background-size: 200px 200px; background-repeat: repeat;"
      >
      </div>

      <div
        class="relative z-10 flex flex-col items-center flex-1 w-full max-w-4xl mx-auto px-6 text-center justify-center"
      >
        <div
          class="flex items-center gap-2 px-4 py-1.5 mb-8 text-xs font-medium text-gray-300 transition-colors border rounded-full bg-white/5 border-white/10 hover:bg-white/10 backdrop-blur-md cursor-pointer"
        >
          <div
            class="w-4 h-4 bg-primary text-black rounded-full flex items-center justify-center text-[10px] font-bold"
          >
            S
          </div>
          مرحبا بكم في شركة شور للبرمجيات!
          <ArrowLeft className="size-4" />
        </div>

        <h1
          class="text-5xl md:text-6xl lg:text-[5rem] leading-[1.1] font-bold -tracking-tight text-white mb-6"
        >
          رواد الحلول والتقنيات الرقمية في <span
            class="text-white/60 text-shadow-sm">المملكة</span
          >
        </h1>

        <p class="text-lg md:text-xl text-gray-400 mb-10 max-w-2xl font-light">
          تقدم شور مجموعة من الحلول المالية التقنية لقطاع الأعمال والأفراد عبر
          مجموعة من منتجات وخدمات المدفوعات الإلكترونية
        </p>

        <div class="flex items-center gap-4">
          <button
            class="px-6 py-3 text-sm font-medium text-white transition-all duration-300 border rounded-full bg-black/40 border-white/10 hover:bg-white/10 hover:scale-105 backdrop-blur-md flex items-center gap-2"
          >
            ابدأ مشروعك
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
            >
          </button>
          <button
            class="px-7 py-3 text-sm font-medium text-black transition-all duration-300 bg-white shadow-[0_0_20px_rgba(255,255,255,0.3)] rounded-full hover:bg-gray-100 hover:scale-105 flex items-center gap-2"
          >
            خدماتنا
          </button>
        </div>
      </div>

      <div class="absolute bottom-10 left-10 flex items-center gap-3 md:flex">
        <div
          class="w-10 h-10 rounded-full bg-white text-black flex items-center justify-center hover:-translate-y-1 transition-transform"
        >
          <!-- Clock Icon -->
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
          >
        </div>
        <span id="saudi-time" class="text-xs text-gray-400 tracking-wide"
          >Loading time...</span
        >
      </div>

      <div
        class="absolute bottom-10 right-10 flex flex-col items-end gap-3 md:flex"
      >
        <span
          id="engineering-caption"
          class="text-sm text-primary font-medium tracking-wider transition-opacity duration-300"
          >حلول الاعمال</span
        >
        <div id="caption-indicators" class="flex items-center gap-2">
          <div
            class="w-5 h-1.5 bg-white rounded-full transition-colors cursor-pointer"
          >
          </div>
          <div
            class="w-5 h-1.5 bg-white/20 rounded-full transition-colors cursor-pointer hover:bg-white/40"
          >
          </div>
          <div
            class="w-5 h-1.5 bg-white/20 rounded-full transition-colors cursor-pointer hover:bg-white/40"
          >
          </div>
          <div
            class="w-5 h-1.5 bg-white/20 rounded-full transition-colors cursor-pointer hover:bg-white/40"
          >
          </div>
          <div
            class="w-5 h-1.5 bg-white/20 rounded-full transition-colors cursor-pointer hover:bg-white/40"
          >
          </div>
          <div
            class="w-5 h-1.5 bg-white/20 rounded-full transition-colors cursor-pointer hover:bg-white/40"
          >
          </div>
          <div
            class="w-5 h-1.5 bg-white/20 rounded-full transition-colors cursor-pointer hover:bg-white/40"
          >
          </div>
        </div>
      </div>

      <div
        class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 cursor-pointer sm:opacity-50 hover:opacity-100 transition-opacity z-10"
        onclick="window.scrollBy({top: window.innerHeight, behavior: 'smooth'})"
      >
        <span
          class="text-[9px] text-white/50 font-semibold tracking-[0.2em] uppercase"
          >Scroll</span
        >
        <div
          class="w-5 h-8 border border-white/20 rounded-full flex justify-center p-1 shadow-[0_0_10px_rgba(255,255,255,0.05)] bg-black/20 backdrop-blur-md"
        >
          <div class="w-1 h-2 bg-primary rounded-full animate-bounce"></div>
        </div>
      </div>
    </div>

    <div
      class="w-full mt-16 px-6 relative z-10 flex flex-col items-center overflow-hidden"
    >
      <p
        class="text-[11px] font-semibold tracking-[0.3em] text-black/40 dark:text-white/40 uppercase mb-10 text-center drop-shadow-sm"
      >
        شركاؤنا في النجاح
      </p>

      <div
        class="w-full max-w-[1440px] overflow-hidden mask-[linear-gradient(to_right,transparent,black_10%,black_90%,transparent)]"
      >
        <div
          class="flex items-center w-max gap-16 md:gap-24 animate-logo-scroll opacity-40 hover:opacity-80 transition-opacity duration-500 grayscale hover:grayscale-0"
        >
          <div
            class="flex items-center gap-2 text-xl font-bold text-black dark:text-white"
          >
            <div
              class="w-0 h-0 border-l-10 border-l-transparent border-r-10 border-r-transparent border-b-18 border-b-white"
            >
            </div> Vercel
          </div>
          <div
            class="text-2xl font-bold tracking-tighter text-black dark:text-white"
          >
            loom
          </div>
          <div
            class="flex items-center gap-1.5 text-xl font-semibold text-black dark:text-white"
          >
            <span
              class="bg-white text-black px-1.5 rounded text-sm italic font-bold leading-tight"
              >$</span
            > Cash App
          </div>
          <div
            class="flex items-center gap-1 text-2xl font-bold tracking-tighter text-black dark:text-white"
          >
            <svg
              class="w-6 h-6 mr-1"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><circle cx="12" cy="12" r="10"></circle><circle
                cx="12"
                cy="12"
                r="5"></circle></svg
            >
            Loops
          </div>
          <div
            class="text-2xl font-bold tracking-tight text-black dark:text-white"
          >
            _zapier
          </div>
          <div
            class="flex items-center gap-1 text-2xl font-bold tracking-tighter text-black dark:text-white"
          >
            ramp <svg
              class="w-5 h-5 mt-1"
              fill="currentColor"
              viewBox="0 0 24 24"><path d="M13 3L4 14h7v7l9-11h-7z"></path></svg
            >
          </div>
          <div
            class="flex items-center gap-2 text-xl font-bold text-black dark:text-white"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"
              ></path></svg
            > Raycast
          </div>

          <div
            class="flex items-center gap-2 text-xl font-bold text-black dark:text-white"
          >
            <div
              class="w-0 h-0 border-l-10 border-l-transparent border-r-10 border-r-transparent border-b-18 border-b-white"
            >
            </div> Vercel
          </div>
          <div
            class="text-2xl font-bold tracking-tighter text-black dark:text-white"
          >
            loom
          </div>
          <div
            class="flex items-center gap-1.5 text-xl font-semibold text-black dark:text-white"
          >
            <span
              class="bg-white text-black px-1.5 rounded text-sm italic font-bold leading-tight"
              >$</span
            > Cash App
          </div>
          <div
            class="flex items-center gap-1 text-2xl font-bold tracking-tighter text-black dark:text-white"
          >
            <svg
              class="w-6 h-6 mr-1"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><circle cx="12" cy="12" r="10"></circle><circle
                cx="12"
                cy="12"
                r="5"></circle></svg
            >
            Loops
          </div>
          <div
            class="text-2xl font-bold tracking-tight text-black dark:text-white"
          >
            _zapier
          </div>
          <div
            class="flex items-center gap-1 text-2xl font-bold tracking-tighter text-black dark:text-white"
          >
            ramp <svg
              class="w-5 h-5 mt-1"
              fill="currentColor"
              viewBox="0 0 24 24"><path d="M13 3L4 14h7v7l9-11h-7z"></path></svg
            >
          </div>
          <div
            class="flex items-center gap-2 text-xl font-bold text-black dark:text-white"
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"
              ></path></svg
            > Raycast
          </div>
        </div>
      </div>
    </div>
  </section>

