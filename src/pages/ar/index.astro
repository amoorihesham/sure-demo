<script>
  function initSaudiTime() {
    const timeEl = document.getElementById('saudi-time');
    if (!timeEl) return;

    function updateTime() {
      const now = new Date();
      const formatter = new Intl.DateTimeFormat('ar-SA', {
        timeZone: 'Asia/Riyadh',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        day: '2-digit',
        month: 'short',
        year: 'numeric',
      });
      timeEl!.textContent = 'وقت السعودية • ' + formatter.format(now);
    }

    updateTime();
    setInterval(updateTime, 1000);
  }

  function initCaptions() {
    const captions = [
      'حلول الاعمال',
      'المنتجات السحابية',
      'الذكاء الاصطناعي ودمج البيانات',
      'حلول البنية التحتية والامان',
      'حلول الخدمات المدارة',
      'منتاجات رقمية مبتكرة',
    ];
    let currentIndex = 0;
    const captionEl = document.getElementById('engineering-caption');
    const dotsContainer = document.getElementById('caption-indicators');
    if (!captionEl || !dotsContainer) return;
    const dots = dotsContainer.children;

    setInterval(() => {
      captionEl.style.opacity = '0';
      setTimeout(() => {
        currentIndex = (currentIndex + 1) % captions.length;
        captionEl.textContent = captions[currentIndex];
        captionEl.style.opacity = '1';

        for (let i = 0; i < dots.length; i++) {
          if (i === currentIndex) {
            dots[i].className =
              'w-5 h-1.5 bg-white rounded-full transition-colors cursor-pointer';
          } else {
            dots[i].className =
              'w-5 h-1.5 bg-white/20 rounded-full transition-colors cursor-pointer hover:bg-white/40';
          }
        }
      }, 300);
    }, 2000);
  }

  function initAll() {
    initSaudiTime();
    initCaptions();
  }

  document.addEventListener('astro:page-load', initAll);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
</script>
