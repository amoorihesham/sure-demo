---
import LucideIcon from '@/components/LucideIcon';
import { content } from '@/content/why';
---

<section id="why" class="w-full relative px-4 md:px-6 py-6 overflow-hidden z-10">
  <div class="max-w-360 mx-auto relative">
    <!-- Background decor -->
    <div class="absolute top-0 right-1/4 w-72 h-72 bg-primary/10 blur-[120px] rounded-full pointer-events-none z-[-1]">
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-12 lg:gap-24 items-center">
      <!-- Text & contact info -->
      <div>
        <h2
          class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-slate-900 dark:text-white mb-4 md:mb-6"
        >
          {content.heading}
          <span class="text-transparent bg-clip-text bg-linear-to-r from-primary to-brand/50">
            {content.headingAccent}
          </span>
        </h2>
      </div>
    </div>
  </div>
</section>
