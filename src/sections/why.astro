---
import LucideIcon from '@/components/LucideIcon';
import { content } from '@/content/why';
---

<section
  id="why"
  class="w-full relative px-4 md:px-6 py-14 overflow-hidden z-10 bg-linear-to-t from-brand/10 to-transparent"
>
  <div class="max-w-360 mx-auto relative">
    <!-- Background decor -->
    <div class="absolute top-0 right-1/4 w-72 h-72 bg-primary/10 blur-[120px] rounded-full pointer-events-none z-[-1]">
    </div>

    <div class="text-center">
      <div>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-slate-900 dark:text-white mb-4">
          {content.heading}
          <span class="text-transparent bg-clip-text bg-linear-to-r from-primary to-brand/50">
            {content.headingAccent}
          </span>
        </h2>
        <p class="max-w-xs font-semibold mx-auto">{content.description}<br />{content.descriptionLine2}</p>
      </div>
      <div class="mt-6">
        <p class="max-w-md mb-4 mx-auto">{content.subDescription}</p>
        <ul class="list-disc px-8 flex flex-col items-center">{content.points.map(p => <li>{p}</li>)}</ul>
      </div>
    </div>
  </div>
</section>
