---
interface Props {
  lang: 'en' | 'ar';
}
const { lang } = Astro.props;

const t = {
  en: {
    tagline:
      'Premium software engineering and design solutions building the digital infrastructure of tomorrow.',
    company: 'Company',
    links: {
      about: 'About Us',
      services: 'Services',
      clients: 'Clients',
    },
    legal: 'Legal',
    legalLinks: {
      privacy: 'Privacy Policy',
      terms: 'Terms of Service',
    },
    copyright: 'Sure Software House. All rights reserved.',
  },
  ar: {
    tagline:
      'حلول هندسة البرمجيات والتصميم المتميزة التي تبني البنية التحتية الرقمية للغد.',
    company: 'الشركة',
    links: {
      about: 'من نحن',
      services: 'خدماتنا',
      clients: 'عملائنا',
    },
    legal: 'قانوني',
    legalLinks: {
      privacy: 'سياسة الخصوصية',
      terms: 'شروط الخدمة',
    },
    copyright: 'شور للبرمجيات. جميع الحقوق محفوظة.',
  },
}[lang];

const year = new Date().getFullYear();
---

<footer
  class="w-full border-t border-slate-200 dark:border-white/5 bg-slate-50 dark:bg-[#02040a] relative z-10 pt-12 md:pt-16 pb-8 px-4 md:px-6"
>
  <div class="max-w-[1440px] mx-auto">
    <div
      class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 mb-12 md:mb-16"
    >
      <!-- Brand -->
      <div class="max-w-sm">
        <a href="/" class="block mb-4 hover:scale-105 transition-transform w-fit">
          <img
            src="/logo.svg"
            alt="logo"
            class="w-20 md:w-24 drop-shadow-[0_0_15px_rgba(0,0,0,0.1)] dark:drop-shadow-[0_0_15px_rgba(255,255,255,0.05)]"
          />
        </a>
        <p class="text-sm md:text-base text-slate-500 dark:text-gray-400">
          {t.tagline}
        </p>
      </div>

      <!-- Nav columns -->
      <div class="flex gap-10 md:gap-12">
        <div class="flex flex-col gap-3">
          <h4 class="font-bold text-slate-900 dark:text-white mb-1">{t.company}</h4>
          <a
            href="#"
            class="text-sm text-slate-500 dark:text-gray-400 hover:text-primary transition-colors"
            >{t.links.about}</a
          >
          <a
            href="#services"
            class="text-sm text-slate-500 dark:text-gray-400 hover:text-primary transition-colors"
            >{t.links.services}</a
          >
          <a
            href="#clients"
            class="text-sm text-slate-500 dark:text-gray-400 hover:text-primary transition-colors"
            >{t.links.clients}</a
          >
        </div>
        <div class="flex flex-col gap-3">
          <h4 class="font-bold text-slate-900 dark:text-white mb-1">{t.legal}</h4>
          <a
            href="#"
            class="text-sm text-slate-500 dark:text-gray-400 hover:text-primary transition-colors"
            >{t.legalLinks.privacy}</a
          >
          <a
            href="#"
            class="text-sm text-slate-500 dark:text-gray-400 hover:text-primary transition-colors"
            >{t.legalLinks.terms}</a
          >
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="border-t border-slate-200 dark:border-white/5 pt-6 md:pt-8 flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <p class="text-slate-500 dark:text-gray-400 text-xs md:text-sm text-center md:text-start">
        &copy; {year} {t.copyright}
      </p>
      <div class="flex gap-4">
        <!-- Twitter/X -->
        <a href="#" class="text-slate-400 hover:text-primary transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
            ><path
              d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"
            ></path></svg
          >
        </a>
        <!-- LinkedIn -->
        <a href="#" class="text-slate-400 hover:text-primary transition-colors">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
            ><path
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
            ></path></svg
          >
        </a>
      </div>
    </div>
  </div>
</footer>
