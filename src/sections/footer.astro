---
import { content } from '@/content/footer';
---

<footer
  class="px-3 md:px-6 w-full bg-linear-to-b from-primary/5 backdrop-blur-2xl to-transparent from-10% to-90% border-t border-brand/20 py-6"
>
  <div class="max-w-360 mx-auto flex items-center justify-between">
    <div class="mt-2">
      <p class="text-slate-500 dark:text-gray-400 text-xs md:text-sm text-center md:text-start">
        &copy;
        {content.copyright}
        {content.year}
      </p>
    </div>
    <div class="flex items-start gap-6 flex-row justify-between">
      <div class="space-x-2">
        <a href={content.legalLinks.privacy.href} class="text-sm underline">{content.legalLinks.privacy.title}</a>
        <a href={content.legalLinks.terms.href} class="text-sm underline">{content.legalLinks.terms.title}</a>
      </div>
    </div>
  </div>
</footer>
