---

<section
  id="services"
  class="w-full relative px-4 md:px-6 py-20 md:py-32 bg-transparent dark:bg-transparent z-10"
>
  <div class="max-w-[1440px] mx-auto">
    <!-- Section header -->
    <div
      class="flex flex-col items-center justify-center text-center max-w-3xl mx-auto mb-14 md:mb-20 relative"
    >
      <div
        class="absolute -top-1/2 left-1/2 -translate-x-1/2 w-64 h-64 bg-primary/20 blur-[100px] rounded-full pointer-events-none"
      >
      </div>

      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-200/50 dark:bg-white/5 border border-slate-300/50 dark:border-white/10 backdrop-blur-md mb-6"
      >
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
        <span
          class="text-xs font-semibold tracking-widest text-slate-700 dark:text-gray-300 uppercase"
          >{t.badge}</span
        >
      </div>

      <h2
        class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-slate-900 dark:text-white mb-4 md:mb-6"
      >
        {t.heading}
        <span
          class="text-transparent bg-clip-text bg-linear-to-r from-primary to-blue-400"
        >
          {t.headingAccent}
        </span>
      </h2>

      <p class="text-base md:text-lg lg:text-xl text-slate-600 dark:text-gray-400">
        {t.subtitle}
      </p>
    </div>

    <!-- Services grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 lg:gap-8 relative">
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-[80%] bg-blue-900/10 blur-[150px] rounded-full pointer-events-none z-[-1]"
      >
      </div>

      {
        services.map(service => (
          <div class="group relative bg-[#ffffff]/60 dark:bg-[#0a0f1d]/60 backdrop-blur-xl border border-slate-200 dark:border-white/5 rounded-3xl p-6 md:p-8 hover:-translate-y-2 transition-all duration-500 hover:shadow-[0_20px_40px_rgba(0,0,0,0.05)] dark:hover:shadow-[0_20px_40px_rgba(0,0,0,0.3)] hover:border-primary/40 dark:hover:border-primary/40 overflow-hidden flex flex-col h-full">
            <div class="absolute top-0 right-0 w-32 h-32 bg-primary/10 rounded-bl-[100px] blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" />

            <div class="w-12 h-12 md:w-14 md:h-14 rounded-2xl bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 flex items-center justify-center text-primary mb-6 md:mb-8 group-hover:scale-110 transition-transform duration-500 shadow-sm shrink-0">
              <Fragment set:html={service.icon} />
            </div>

            <h3 class="text-lg md:text-xl font-bold text-slate-800 dark:text-white mb-3 md:mb-4">
              {service.title}
            </h3>
            <p class="text-sm md:text-base text-slate-600 dark:text-gray-400 leading-relaxed mb-6 md:mb-8 grow">
              {service.description}
            </p>

            <div class="flex items-center gap-2 text-sm font-semibold text-primary mt-auto">
              <span>{t.learnMore}</span>
              <svg
                class="w-4 h-4 group-hover:translate-x-1 rtl:rotate-180 rtl:group-hover:-translate-x-1 transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17 8l4 4m0 0l-4 4m4-4H3"
                />
              </svg>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
