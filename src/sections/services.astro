---
import LucideIcon from '../components/LucideIcon';
import { suits, content } from '@/content/services';
---

<section id="services" class="w-full relative px-4 md:px-6 py-20 md:py-32 bg-transparent dark:bg-transparent z-10">
  <div class="max-w-360 mx-auto">
    <!-- Section header -->
    <div class="flex flex-col items-center justify-center text-center max-w-3xl mx-auto mb-14 md:mb-20 relative">
      <div
        class="absolute -top-1/2 left-1/2 -translate-x-1/2 w-64 h-64 bg-primary/20 blur-[100px] rounded-full pointer-events-none"
      >
      </div>

      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-200/50 dark:bg-white/5 border border-slate-300/50 dark:border-white/10 backdrop-blur-md mb-6"
      >
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
        <span class="text-xs font-semibold tracking-widest text-slate-700 dark:text-gray-300 uppercase"
          >{content.badge}</span
        >
      </div>

      <h2
        class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-slate-900 dark:text-white mb-4 md:mb-6"
      >
        {content.heading}
        <span class="text-transparent bg-clip-text bg-linear-to-r from-primary to-blue-400">
          {content.headingAccent}
        </span>
      </h2>

      <p class="text-base md:text-lg lg:text-xl text-slate-600 dark:text-gray-400">
        {content.subtitle}
      </p>
    </div>

    <div class="space-y-6">
      {
        suits.map(suit => (
          <div class="bg-transparent relative backdrop-blur-3xl shadow-lg shadow-brand/10 rounded-md border border-brand/20  group overflow-hidden hover:shadow-brand/20 transition-all duration-300 flex flex-col">
            <div class="absolute -top-1/6 -right-2/6 w-[50%] h-[50%] bg-primary/10 blur-3xl  rounded-full pointer-events-none group-hover:bg-primary/20 transition-all duration-300" />
            <div class="absolute -bottom-1/6 -left-2/6 w-[50%] h-[50%] bg-brand/10 blur-3xl group-hover:bg-brand/20 transition-all duration-300  rounded-full pointer-events-none" />
            <div class="w-full py-6  flex items-center justify-center border-b border-brand/10">
              {suit.image && <img src={suit.image} alt="Clario DataStream logo" class="w-28" />}
              {!suit.image && <LucideIcon name="Building2" size={28} />}
            </div>
            <div class="flex-1 grid grid-cols-3 px-6 py-3 gap-6">
              {suit.apps.map(app => (
                <div class="bg-primary/5 p-4 rounded-md">
                  <div class="flex items-center gap-2">
                    <div class={`${app.backgroundColor} rounded-lg p-2`}>
                      <LucideIcon name={app.icon} size={18} />
                    </div>
                    <h4>{app.name}</h4>
                  </div>
                  <div class="mt-2 ">
                    <p class="text-sm text-muted-foreground">{app.description}</p>
                    <ul class="list-disc p-0 mt-2 text-xs space-y-1 px-6">
                      {app.features.map(feat => (
                        <li>{feat}</li>
                      ))}
                    </ul>
                  </div>
                </div>
              ))}
            </div>
            <div class="w-full py-6  flex items-center justify-center border-t border-brand/10 text-primary">
              {suit.compliance}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
