  ar: {
    badge: 'خدماتنا',
    heading: 'حلول رقمية',
    headingAccent: 'متميزة',
    subtitle:
      'حلول شاملة مصممة للتوسع، والارتقاء بعلامتك التجارية، والسيطرة على المشهد الرقمي.',
    learnMore: 'اعرف المزيد',
  },
}[lang];

const services = {
  en: [
    {
