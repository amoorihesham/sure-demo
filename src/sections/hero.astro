---
import { content } from '@/content/hero';
---

<section class="w-full relative px-3 sm:px-4 md:px-6 pb-16 overflow-hidden">
  <!-- Hero Card Container -->
  <div
    class="w-full max-w-360 mx-auto min-h-150 md:min-h-[85vh] bg-primary/10 dark:bg-[#050814]/80 backdrop-blur-3xl rounded-2xl md:rounded-[2rem] relative overflow-hidden border border-white/5 shadow-2xl flex flex-col justify-center"
  >
    <!-- Background glows -->
    <div
      class="absolute -top-1/2 -right-1/4 w-[80%] h-[80%] bg-primary/20 blur-[140px] rounded-full pointer-events-none"
    >
    </div>
    <div
      class="absolute -bottom-1/2 -left-1/4 w-[80%] h-[80%] bg-primary/10 blur-[130px] rounded-full pointer-events-none"
    >
    </div>

    <!-- Vertical meteor streaks -->
    <div class="absolute inset-x-0 bottom-0 h-[60%] z-0 flex justify-center pointer-events-none opacity-60">
      <div class="w-[1.5px] bg-linear-to-b from-transparent to-primary/20 h-full relative mx-[6%]">
        <span
          class="absolute rounded-full block w-full h-32 bg-linear-to-b from-transparent to-primary bottom-32 opacity-80 blur-[2px] animate-pulse"
        ></span>
      </div>
      <div class="w-[1.5px] bg-linear-to-b from-transparent to-primary/20 h-[80%] relative mx-[4%]">
        <span
          class="absolute rounded-full block w-full h-40 bg-linear-to-b from-transparent to-primary/80 bottom-10 opacity-70 blur-[2px]"
        ></span>
      </div>
      <div class="w-px bg-linear-to-b from-transparent to-primary/10 h-[90%] relative mx-[7%]">
        <span
          class="absolute rounded-full block w-full h-24 bg-linear-to-b from-transparent to-primary bottom-1/4 opacity-90 blur-[2px]"
        ></span>
      </div>
    </div>

    <!-- Starry particle overlays -->
    <div
      class="absolute inset-0 z-0 pointer-events-none opacity-10 animate-ping mix-blend-screen"
      style="background-image: radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.8) 100%, transparent), radial-gradient(2px 2px at 40% 50%, rgba(255,255,255,0.3) 100%, transparent), radial-gradient(1.5px 1.5px at 80% 30%, rgba(255,255,255,0.6) 100%, transparent), radial-gradient(2.5px 2.5px at 90% 80%, rgba(255,255,255,0.4) 100%, transparent), radial-gradient(1px 1px at 30% 70%, rgba(255,255,255,0.9) 100%, transparent), radial-gradient(2px 2px at 60% 10%, rgba(255,255,255,0.5) 100%, transparent), radial-gradient(1px 1px at 70% 90%, rgba(255,255,255,0.7) 100%, transparent), radial-gradient(1.5px 1.5px at 20% 80%, rgba(255,255,255,0.6) 100%, transparent); background-size: 140px 140px; background-repeat: repeat;"
    >
    </div>
    <div
      class="absolute inset-0 z-0 pointer-events-none opacity-5 mix-blend-screen"
      style="background-image: radial-gradient(1.5px 1.5px at 15% 15%, rgba(255,255,255,0.5) 100%, transparent), radial-gradient(1px 1px at 85% 85%, rgba(255,255,255,0.7) 100%, transparent), radial-gradient(2px 2px at 50% 25%, rgba(255,255,255,0.4) 100%, transparent); background-size: 200px 200px; background-repeat: repeat;"
    >
    </div>

    <!-- Central content -->
    <div
      class="relative z-10 flex flex-col items-center flex-1 w-full max-w-4xl mx-auto px-4 sm:px-6 text-center justify-center py-16 md:py-0"
    >
      <!-- Badge pill -->
      <div
        class="flex items-center gap-2 px-4 py-1.5 mb-6 md:mb-8 text-xs font-medium dark:text-gray-300 transition-colors border rounded-full bg-white/5 border-white/10 hover:bg-white/10 backdrop-blur-md cursor-pointer max-w-[min(90vw,28rem)] overflow-hidden"
      >
        <div
          class="w-4 h-4 bg-primary text-white rounded-full flex items-center justify-center text-[10px] font-bold shrink-0"
        >
          S
        </div>
        <span class="truncate">{content.badge}</span>
        <svg class="w-3 h-3 shrink-0 rtl:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"
          ></path></svg
        >
      </div>

      <!-- Headline -->
      <h1
        class="text-3xl sm:text-4xl md:text-6xl lg:text-[5rem] leading-[1.15] font-bold tracking-tight text-foreground dark:text-white mb-4 md:mb-6"
      >
        {content.headline}
        <span class="text-brand dark:text-white/60 text-shadow-sm"> {content.headlineAccent}</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-base sm:text-lg md:text-xl text-gray-700 dark:text-gray-400 mb-8 md:mb-10 max-w-2xl font-light">
        {content.subtitle}
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-wrap justify-center items-center gap-3 md:gap-4">
        <button
          class="px-7 py-3 text-sm font-medium text-background transition-all duration-300 bg-primary shadow-[0_0_20px_rgba(255,255,255,0.3)] rounded-full hover:bg-primary/ hover:scale-105"
        >
          {content.servicesBtn}
        </button>
      </div>
    </div>

    <!-- Bottom-left: KSA clock — hidden on mobile -->
    <div class="absolute bottom-10 left-10 hidden md:flex items-center gap-3">
      <div
        class="w-10 h-10 rounded-full bg-primary/10 text-foreground flex items-center justify-center hover:-translate-y-1 transition-transform"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
        >
      </div>
      <span id="saudi-time" class="text-xs text-brand tracking-wide">Loading...</span>
    </div>

    <!-- Bottom-right: rotating caption — hidden on mobile -->
    <div class="absolute bottom-10 right-10 hidden md:flex flex-col items-end gap-3">
      <span
        id="engineering-caption"
        class="text-sm text-primary font-medium tracking-wider transition-opacity duration-300"
        >{content.captions[0]}</span
      >
      <div id="caption-indicators" class="flex items-center gap-2">
        {
          content.captions.map((_, i) => (
            <div
              class={`w-5 h-1.5 ${i === 0 ? 'bg-white' : 'bg-white/20 hover:bg-white/40'} rounded-full transition-colors cursor-pointer`}
            />
          ))
        }
      </div>
    </div>

    <!-- Center-bottom scroll indicator -->
    <div
      class="absolute bottom-6 md:bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 cursor-pointer opacity-50 hover:opacity-100 transition-opacity z-10"
      onclick="window.scrollBy({top: window.innerHeight, behavior: 'smooth'})"
    >
      <span class="text-[9px] text-white/50 font-semibold tracking-[0.2em] uppercase">{content.scrollLabel}</span>
      <div
        class="w-5 h-8 border border-white/20 rounded-full flex justify-center p-1 shadow-[0_0_10px_rgba(255,255,255,0.05)] bg-black/20 backdrop-blur-md"
      >
        <div class="w-1 h-2 bg-primary rounded-full animate-bounce"></div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ captions: content.captions, timePrefix: content.timePrefix, timeLocale: content.timeLocale }}>
  function initSaudiTime() {
    var timeEl = document.getElementById('saudi-time');
    if (!timeEl) return;
    function updateTime() {
      var now = new Date();
      var formatter = new Intl.DateTimeFormat(timeLocale, {
        timeZone: 'Asia/Riyadh',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        day: '2-digit',
        month: 'short',
        year: 'numeric',
      });
      timeEl.textContent = timePrefix + formatter.format(now);
    }
    updateTime();
    setInterval(updateTime, 1000);
  }

  function initCaptions() {
    var captionEl = document.getElementById('engineering-caption');
    var dotsContainer = document.getElementById('caption-indicators');
    if (!captionEl || !dotsContainer) return;
    var dots = dotsContainer.children;
    var currentIndex = 0;

    setInterval(function () {
      captionEl.style.opacity = '0';
      setTimeout(function () {
        currentIndex = (currentIndex + 1) % captions.length;
        captionEl.textContent = captions[currentIndex];
        captionEl.style.opacity = '1';
        for (var i = 0; i < dots.length; i++) {
          dots[i].className =
            i === currentIndex
              ? 'w-5 h-1.5 bg-primary rounded-full transition-colors cursor-pointer'
              : 'w-5 h-1.5 bg-brand/20 rounded-full transition-colors cursor-pointer hover:bg-white/40';
        }
      }, 300);
    }, 2000);
  }

  function initAll() {
    initSaudiTime();
    initCaptions();
  }

  document.addEventListener('astro:page-load', initAll);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
</script>
