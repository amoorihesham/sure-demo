---
interface Props {
  lang: 'en' | 'ar';
}
const { lang } = Astro.props;

const t = {
  en: {
    badge: 'Clients',
    heading: 'Trusted by',
    headingAccent: 'Visionaries',
    subtitle:
      'Sure Global Technology is proud of the immense trust of its clients, who have exceeded 200 across multiple sectors, for whom we have provided various and diverse technological solutions.',
  },
  ar: {
    badge: 'عملائنا',
    heading: 'موثوق به من قبل',
    headingAccent: 'أصحاب الرؤى',
    subtitle:
      'تفخر شور العالمية للتقنية بالثقة الكبيرة من عملائها الذين تجاوزوا 200 في قطاعات متعددة، قدمت لهم حلولا تقنية مختلفة ومتنوعة',
  },
}[lang];

const testimonials = [
  {
    name: 'Sarah Jenkins',
    role: 'CTO, FinTech Next',
    content:
      'Sure completely transformed our backend architecture. The new API infrastructure they designed handles 10x our previous traffic with zero latency spikes or downtime.',
    rating: 5,
    avatar: 'S',
  },
  {
    name: 'Omar Al-Fayed',
    role: 'Founder, RetailFlow',
    content:
      "The level of engineering quality and attention to detail during our mobile app rebuild was staggering. They don't just write code; they build scalable digital businesses.",
    rating: 5,
    avatar: 'O',
  },
  {
    name: 'Elena Rodriguez',
    role: 'VP Product, HealthSync',
    content:
      'Their UI/UX team worked seamlessly with the frontend engineers to deliver a pixel-perfect, native-feeling healthcare app in half the anticipated timeline. Truly impressive.',
    rating: 5,
    avatar: 'E',
  },
];
---

<section
  id="clients"
  class="w-full relative px-4 md:px-6 py-20 md:py-32 bg-transparent dark:bg-transparent z-10 overflow-hidden"
>
  <div class="max-w-[1440px] mx-auto relative">
    <!-- Background glows -->
    <div
      class="absolute top-1/3 right-1/4 w-96 h-96 bg-primary/10 blur-[120px] rounded-full pointer-events-none z-[-1]"
    >
    </div>
    <div
      class="absolute bottom-0 left-10 w-72 h-72 bg-blue-500/10 blur-[100px] rounded-full pointer-events-none z-[-1]"
    >
    </div>

    <!-- Section header -->
    <div
      class="flex flex-col items-center justify-center text-center max-w-3xl mx-auto mb-14 md:mb-20"
    >
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-200/50 dark:bg-white/5 border border-slate-300/50 dark:border-white/10 backdrop-blur-md mb-6"
      >
        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
        <span
          class="text-xs font-semibold tracking-widest text-slate-700 dark:text-gray-300 uppercase"
          >{t.badge}</span
        >
      </div>

      <h2
        class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-slate-900 dark:text-white mb-4 md:mb-6"
      >
        {t.heading}
        <span class="text-transparent bg-clip-text bg-linear-to-r from-primary to-blue-400">
          {t.headingAccent}
        </span>
      </h2>

      <p class="text-base md:text-lg lg:text-xl text-slate-600 dark:text-gray-400">
        {t.subtitle}
      </p>
    </div>

    <!-- Testimonials grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6 lg:gap-8">
      {
        testimonials.map(t => (
          <div class="group relative bg-[#ffffff]/60 dark:bg-[#0a0f1d]/60 backdrop-blur-xl border border-slate-200 dark:border-white/5 rounded-3xl p-6 md:p-8 hover:-translate-y-2 transition-all duration-500 hover:shadow-[0_20px_40px_rgba(0,0,0,0.05)] dark:hover:shadow-[0_20px_40px_rgba(0,0,0,0.3)] hover:border-primary/40 dark:hover:border-primary/40 flex flex-col justify-between">
            <!-- Stars -->
            <div class="flex items-center gap-1 mb-6 md:mb-8">
              {Array.from({ length: t.rating }).map(() => (
                <svg
                  class="w-4 h-4 md:w-5 md:h-5 text-yellow-500 drop-shadow-[0_0_8px_rgba(234,179,8,0.5)]"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Quote -->
            <p class="text-slate-700 dark:text-gray-300 text-base md:text-lg leading-relaxed mb-8 md:mb-10 italic relative z-10">
              "{t.content}"
            </p>

            <!-- Author -->
            <div class="flex items-center gap-3 md:gap-4 mt-auto relative z-10">
              <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-linear-to-br from-primary to-blue-600 flex items-center justify-center text-white font-bold text-base md:text-lg shadow-[0_0_15px_rgba(111,0,255,0.3)] relative group-hover:scale-105 transition-transform shrink-0">
                <span class="relative z-10">{t.avatar}</span>
                <div class="absolute inset-0 bg-primary rounded-full blur-md opacity-40 group-hover:opacity-80 transition-opacity duration-500" />
              </div>
              <div>
                <h4 class="text-slate-900 dark:text-white font-bold text-sm md:text-base transition-colors group-hover:text-primary">
                  {t.name}
                </h4>
                <p class="text-slate-500 dark:text-gray-400 text-xs md:text-sm">{t.role}</p>
              </div>
            </div>

            <!-- Decorative quote icon -->
            <svg
              class="absolute top-5 end-5 w-16 h-16 md:w-24 md:h-24 text-slate-200/50 dark:text-white/5 opacity-50 pointer-events-none"
              fill="currentColor"
              viewBox="0 0 32 32"
            >
              <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4z" />
            </svg>
          </div>
        ))
      }
    </div>
  </div>
</section>
