---
import { ModeToggle } from '@/components/ui/ModeToggle';
import { LocaleToggle } from '@/components/ui/LocaleToggle';

interface Props {
  lang: 'en' | 'ar';
}
const { lang } = Astro.props;

const navItems =
  lang === 'ar'
    ? [
        { label: 'الرئيسية', href: '#' },
        { label: 'من نحن', href: '#' },
        { label: 'خدماتنا', href: '#services' },
        { label: 'العملاء', href: '#clients' },
        { label: 'تواصل معنا', href: '#contact' },
      ]
    : [
        { label: 'Home', href: '#' },
        { label: 'About Us', href: '#' },
        { label: 'Services', href: '#services' },
        { label: 'Clients', href: '#clients' },
        { label: 'Contact Us', href: '#contact' },
      ];

const prefsLabel = lang === 'ar' ? 'المظهر واللغة' : 'Theme & Language';
---

<header class="sticky top-0 bg-background/5 backdrop-blur-lg z-50">
  <div class="flex justify-between items-center px-4 md:px-6 py-2">
    <!-- Logo -->
    <div class="shrink-0">
      <a href="/" class="block hover:scale-105 transition-transform duration-300">
        <img
          src="/logo.svg"
          alt="logo"
          class="w-20 md:w-24 drop-shadow-[0_0_15px_rgba(0,0,0,0.1)] dark:drop-shadow-[0_0_15px_rgba(255,255,255,0.05)]"
        />
      </a>
    </div>

    <!-- Desktop: toggles + nav pill -->
    <div class="hidden md:flex items-center justify-between w-[70%] xl:w-2/3">
      <div
        class="flex items-center gap-2 p-1.5 rounded-full bg-slate-200/50 dark:bg-white/5 border border-slate-300/50 dark:border-white/10 backdrop-blur-md shadow-sm dark:shadow-md transition-all hover:bg-slate-300/70 dark:hover:bg-white/10"
      >
        <ModeToggle client:only />
        <LocaleToggle client:only />
      </div>

      <nav
        class="bg-slate-800/90 dark:bg-[#0a0f1d]/80 border border-slate-700/50 dark:border-white/10 text-white dark:text-gray-300 flex items-center gap-6 xl:gap-8 rounded-full px-6 xl:px-8 py-3 backdrop-blur-xl shadow-lg dark:shadow-[0_8px_32px_rgba(0,0,0,0.2)]"
      >
        {
          navItems.map(item => (
            <a
              href={item.href}
              class="text-sm font-medium hover:text-primary cursor-pointer transition-colors duration-300 relative group whitespace-nowrap"
            >
              {item.label}
              <span class="absolute -bottom-1.5 left-1/2 w-0 h-0.5 bg-primary -translate-x-1/2 transition-all duration-300 group-hover:w-full rounded-full" />
            </a>
          ))
        }
      </nav>
    </div>

    <!-- Mobile: hamburger only -->
    <button
      id="mobile-menu-btn"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      class="md:hidden w-11 h-11 flex flex-col justify-center items-center gap-[5px] rounded-full bg-slate-800/90 dark:bg-white/5 border border-slate-700/50 dark:border-white/10 shrink-0"
    >
      <span class="menu-bar block w-[18px] h-[2px] bg-white rounded-full origin-center transition-all duration-300"></span>
      <span class="menu-bar block w-[18px] h-[2px] bg-white rounded-full origin-center transition-all duration-300"></span>
      <span class="menu-bar block w-[18px] h-[2px] bg-white rounded-full origin-center transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-slate-900/98 dark:bg-[#050814]/98 backdrop-blur-xl border-t border-white/5 px-4 pb-5"
  >
    <!-- Nav links -->
    <nav class="flex flex-col mb-2">
      {
        navItems.map(item => (
          <a
            href={item.href}
            class="mobile-nav-link text-sm font-medium text-gray-300 hover:text-primary py-3.5 border-b border-white/5 last:border-0 transition-colors duration-200"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Theme & locale toggles -->
    <div class="border-t border-white/10 pt-4 flex items-center justify-between">
      <span class="text-xs font-medium text-gray-500">{prefsLabel}</span>
      <div
        class="flex items-center gap-1 p-1 rounded-full bg-white/5 border border-white/10"
      >
        <ModeToggle client:only />
        <LocaleToggle client:only />
      </div>
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    const bars = btn.querySelectorAll<HTMLElement>('.menu-bar');

    function openMenu() {
      menu.classList.remove('hidden');
      btn.setAttribute('aria-expanded', 'true');
      bars[0].style.transform = 'translateY(7px) rotate(45deg)';
      bars[1].style.opacity = '0';
      bars[2].style.transform = 'translateY(-7px) rotate(-45deg)';
    }

    function closeMenu() {
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
      bars[0].style.transform = '';
      bars[1].style.opacity = '1';
      bars[2].style.transform = '';
    }

    btn.addEventListener('click', () => {
      menu.classList.contains('hidden') ? openMenu() : closeMenu();
    });

    menu.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }

  document.addEventListener('astro:page-load', initMobileMenu);
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileMenu);
  } else {
    initMobileMenu();
  }
</script>
