---

---

<section
  id="contact"
  class="w-full relative px-6 py-24 md:py-32 overflow-hidden z-10"
>
  <div class="max-w-[1440px] mx-auto relative">
    <!-- Background Decor -->
    <div
      class="absolute top-0 right-1/4 w-72 h-72 bg-primary/10 blur-[120px] rounded-full pointer-events-none z-[-1]"
    >
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-center">
      <!-- Text & Contact Info -->
      <div>
        <div
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-200/50 dark:bg-white/5 border border-slate-300/50 dark:border-white/10 backdrop-blur-md mb-6"
        >
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          <span
            class="text-xs font-semibold tracking-widest text-slate-700 dark:text-gray-300 uppercase"
            >Contact Us</span
          >
        </div>

        <h2
          class="text-4xl md:text-5xl font-bold tracking-tight text-slate-900 dark:text-white mb-6"
        >
          Let's Build Something <span
            class="text-transparent bg-clip-text bg-linear-to-r from-primary to-blue-400"
            >Extraordinary</span
          >
        </h2>

        <p class="text-lg text-slate-600 dark:text-gray-400 mb-10">
          Ready to transform your digital strategy? Get in touch with our team
          of engineers and designers to discuss your next big project.
        </p>

        <div class="space-y-6">
          <div class="flex items-center gap-4">
            <div
              class="w-12 h-12 rounded-full bg-slate-200/50 dark:bg-white/5 border border-slate-300 dark:border-white/10 flex items-center justify-center text-primary"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
                ></path></svg
              >
            </div>
            <div>
              <p class="text-sm text-slate-500 dark:text-gray-400">Email us</p>
              <p class="text-base font-semibold text-slate-900 dark:text-white">
                hello@sure.sa
              </p>
            </div>
          </div>

          <div class="flex items-center gap-4">
            <div
              class="w-12 h-12 rounded-full bg-slate-200/50 dark:bg-white/5 border border-slate-300 dark:border-white/10 flex items-center justify-center text-primary"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
                ></path></svg
              >
            </div>
            <div>
              <p class="text-sm text-slate-500 dark:text-gray-400">Visit us</p>
              <p class="text-base font-semibold text-slate-900 dark:text-white">
                Riyadh, Saudi Arabia
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div
        class="bg-[#ffffff]/60 dark:bg-[#0a0f1d]/60 backdrop-blur-xl border border-slate-200 dark:border-white/5 rounded-3xl p-8 shadow-xl relative"
      >
        <form class="space-y-6" onsubmit="event.preventDefault();">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label
                class="text-sm font-medium text-slate-700 dark:text-gray-300"
                >First Name</label
              >
              <input
                type="text"
                class="w-full bg-white dark:bg-black/20 border border-slate-300 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all"
                placeholder="John"
              />
            </div>
            <div class="space-y-2">
              <label
                class="text-sm font-medium text-slate-700 dark:text-gray-300"
                >Last Name</label
              >
              <input
                type="text"
                class="w-full bg-white dark:bg-black/20 border border-slate-300 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all"
                placeholder="Doe"
              />
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium text-slate-700 dark:text-gray-300"
              >Work Email</label
            >
            <input
              type="email"
              class="w-full bg-white dark:bg-black/20 border border-slate-300 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all"
              placeholder="john@company.com"
            />
          </div>

          <div class="space-y-2">
            <label class="text-sm font-medium text-slate-700 dark:text-gray-300"
              >Message</label
            >
            <textarea
              rows="4"
              class="w-full bg-white dark:bg-black/20 border border-slate-300 dark:border-white/10 rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 transition-all resize-none"
              placeholder="Tell us about your project..."></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-primary hover:bg-primary/90 text-white font-semibold rounded-xl px-6 py-4 transition-colors"
          >
            Send Message
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
