---
import LucideIcon from '@/components/LucideIcon';
import { content } from '@/content/contact';
import ContactForm from '@/components/Contact.astro';
---

<section id="contact" class="w-full relative px-4 md:px-6 py-20 md:py-32 overflow-hidden z-10">
  <div class="max-w-360 mx-auto relative">
    <!-- Background decor -->
    <div class="absolute top-0 right-1/4 w-72 h-72 bg-primary/10 blur-[120px] rounded-full pointer-events-none z-[-1]">
    </div>

    <div class="flex items-stretch flex-col md:flex-row justify-between gap-10 md:gap-14">
      <!-- Text & contact info -->
      <div class="flex flex-col justify-between items-start flex-1/2">
        <div>
          <div
            class="w-fit inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-200/50 border border-slate-300/50 backdrop-blur-md mb-6"
          >
            <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
            <span class="text-xs font-semibold tracking-widest text-slate-700 dark:text-gray-300 uppercase"
              >{content.badge}</span
            >
          </div>

          <h2
            class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-slate-900 dark:text-white mb-4 md:mb-6"
          >
            {content.heading}
            <span class="text-transparent bg-clip-text bg-linear-to-r from-primary to-brand/50">
              {content.headingAccent}
            </span>
          </h2>

          <p class="text-base md:text-lg text-slate-600 max-w-2xl mb-8 md:mb-10">
            {content.subtitle}
          </p>
        </div>

        <div class="space-y-5 md:space-y-6 mt-auto">
          <!-- Email -->
          <div class="flex items-center gap-4">
            <div
              class="w-11 h-11 md:w-12 md:h-12 rounded-full bg-slate-200/50 dark:bg-white/5 border border-slate-300 dark:border-white/10 flex items-center justify-center text-primary shrink-0"
            >
              <LucideIcon name="Mail" />
            </div>
            <div>
              <p class="text-sm text-slate-500 dark:text-gray-400">
                {content.emailLabel}
              </p>
              <p class="text-sm md:text-base font-semibold text-slate-900 dark:text-white">
                {content.email}
              </p>
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-center gap-4">
            <div
              class="w-11 h-11 md:w-12 md:h-12 rounded-full bg-slate-200/50 dark:bg-white/5 border border-slate-300 dark:border-white/10 flex items-center justify-center text-primary shrink-0"
            >
              <LucideIcon name="MapPin" />
            </div>
            <div>
              <p class="text-sm text-slate-500 dark:text-gray-400">
                {content.locationLabel}
              </p>
              <p class="text-sm md:text-base font-semibold text-slate-900 dark:text-white">
                {content.location}
              </p>
            </div>
          </div>
        </div>
      </div>

      <ContactForm />
    </div>
  </div>
</section>
