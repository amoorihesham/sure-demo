---
import { ModeToggle } from "@/components/ui/ModeToggle";
import { LocaleToggle } from "@/components/ui/LocaleToggle";


---


<header class="flex justify-between items-center py-3">
    <div>
        <a><img src="/logo.svg" alt="logo" class="w-20"/></a>
    </div>
    <div class="flex items-center justify-between w-2/3">
        <div class="flex items-center gap-3">
            <ModeToggle client:only/>
            <LocaleToggle client:only/>
        </div>
        <nav class="bg-brand text-background dark:text-foreground flex items-center gap-6 w-fit rounded-full px-6 py-2">
            <a >Home</a>
            <a >About Us</a>
            <a >Services</a>
            <a >Clients</a>
            <a >Contact Us</a>
        </nav>
    </div>
</header>